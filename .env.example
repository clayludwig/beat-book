# Copy this file to .env and fill in real values.
# Used by app.py at startup (see the loader near the top of that file).

# OpenAI — used only for embeddings (text-embedding-3-small).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — used for the chat models (ingest normalization, cluster
# labeling, the interview agent) and the research agent.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enable extended thinking on Claude Sonnet 4.6. Higher
# quality but materially slower. Default: off. Set to true/1/yes/on to
# enable. Note: thinking is incompatible with forced tool_choice, so the
# ingest normalization step ignores this flag.
# ENABLE_THINKING=true
